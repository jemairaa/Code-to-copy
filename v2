doc1_key = "iata"   # Doc 1's IATA column
doc2_key = "iata_data"   # Doc 2's IATA column

# Reset the Doc 2 columns to blank first, so re-running starts clean
for new_name in new_cols:
    result[new_name] = ""

def clean_key(value):
    text = str(value).strip().upper()
    if text in ("", "NAN", "NONE", "NULL"):
        return ""
    return text

result_key = result[doc1_key].map(clean_key)
doc2_keys  = doc2[doc2_key].map(clean_key)

doc2_lookup = doc2.copy()
doc2_lookup["_key"] = doc2_keys
doc2_lookup = doc2_lookup[doc2_lookup["_key"] != ""]
doc2_lookup = doc2_lookup.drop_duplicates("_key", keep="first").set_index("_key")

has_iata = result_key != ""
matched  = has_iata & result_key.isin(doc2_lookup.index)

for original_col, new_name in zip(doc2.columns, new_cols):
    result.loc[matched, new_name] = result_key[matched].map(doc2_lookup[original_col])

print("Doc 1 rows total       :", len(result))
print("Doc 1 rows missing IATA :", int((~has_iata).sum()))
print("Rows matched            :", int(matched.sum()))
print("Rows with no match      :", int((~matched).sum()))

import re

# Values that really mean "blank" (NOT "NA"/"N/A" — those can be real codes)
NA_PLACEHOLDERS = {"", "NAN", "NONE", "NULL"}

def tidy(df):
    df = df.copy()

    # Clean column NAMES
    df.columns = [
        re.sub(r"\s+", " ", str(c).replace("\xa0", " ")).strip()
        for c in df.columns
    ]

    # Clean every VALUE in every column
    for col in df.columns:
        cleaned = (
            df[col].astype(str)
            .str.replace("\xa0", " ", regex=False)   # non-breaking space -> normal
            .str.replace(r"\s+", " ", regex=True)    # collapse repeated spaces
            .str.strip()                             # trim ends
        )
        is_blank = cleaned.str.upper().isin(NA_PLACEHOLDERS)
        df[col] = cleaned.where(~is_blank, "")       # nan/none/null -> ""
    return df


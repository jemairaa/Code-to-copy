#!/usr/bin/env python3
"""
Match two CSV files on a key column and output the rows from file 2
whose key value exists in file 1 (exact match).

Usage:
    python match_csv.py file1.csv file2.csv \
        --key1 id --key2 customer_id \
        --output matched.csv

If --key2 is omitted, --key1 is used for both files.
If --output is omitted, results print to stdout.
"""

import argparse
import csv
import sys


def load_keys(path, key_col):
    """Return a set of all values in key_col of the given CSV."""
    with open(path, newline="", encoding="utf-8-sig") as f:
        reader = csv.DictReader(f)
        if key_col not in reader.fieldnames:
            sys.exit(f"Error: column '{key_col}' not found in {path}. "
                     f"Available columns: {reader.fieldnames}")
        return {row[key_col] for row in reader}


def match_rows(file1, file2, key1, key2, output):
    keys1 = load_keys(file1, key1)

    with open(file2, newline="", encoding="utf-8-sig") as f:
        reader = csv.DictReader(f)
        if key2 not in reader.fieldnames:
            sys.exit(f"Error: column '{key2}' not found in {file2}. "
                     f"Available columns: {reader.fieldnames}")

        out_stream = open(output, "w", newline="", encoding="utf-8") if output else sys.stdout
        try:
            writer = csv.DictWriter(out_stream, fieldnames=reader.fieldnames)
            writer.writeheader()

            matched = 0
            total = 0
            for row in reader:
                total += 1
                if row[key2] in keys1:   # exact match
                    writer.writerow(row)
                    matched += 1
        finally:
            if output:
                out_stream.close()

    print(f"Matched {matched} of {total} rows from file 2.", file=sys.stderr)


def main():
    p = argparse.ArgumentParser(description="Match file 2 rows to file 1 on a key column.")
    p.add_argument("file1", help="First CSV (the reference set of keys)")
    p.add_argument("file2", help="Second CSV (rows to filter)")
    p.add_argument("--key1", required=True, help="Key column name in file 1")
    p.add_argument("--key2", help="Key column name in file 2 (defaults to --key1)")
    p.add_argument("--output", help="Output CSV path (defaults to stdout)")
    args = p.parse_args()

    match_rows(args.file1, args.file2, args.key1, args.key2 or args.key1, args.output)


if __name__ == "__main__":
    main()

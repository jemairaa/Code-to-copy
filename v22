import pandas as pd

file1 = "file1.csv"   # <- set to your doc1 filename
file2 = "file2.csv"   # <- set to your doc2 filename
key1 = "iata"         # key column in doc1
key2 = "iata_code"    # key column in doc2

df1 = pd.read_csv(file1, encoding="latin-1")
df2 = pd.read_csv(file2, encoding="latin-1")

print("doc1 columns:", list(df1.columns))
print("doc2 columns:", list(df2.columns))
print("doc1 total rows:", len(df1))

# Treat empty strings / whitespace-only cells as "no value" (NaN) in both keys.
df1[key1] = df1[key1].replace(r"^\s*$", pd.NA, regex=True)
df2[key2] = df2[key2].replace(r"^\s*$", pd.NA, regex=True)

# Drop doc2 rows with no code, so a blank iata can never match a blank code.
df2 = df2.dropna(subset=[key2])

# doc2 has the same iata_code repeated many times, which multiplies rows on a join.
# Keep only the FIRST matching doc2 row per code so each doc1 row maps to one row.
df2_unique = df2.drop_duplicates(subset=key2, keep="first")
print("doc2 total rows:", len(df2), "| unique", key2, ":", len(df2_unique))

# Full iata column from doc1, with the one matching doc2 row attached beside it.
matched = df1[[key1]].merge(df2_unique, left_on=key1, right_on=key2, how="left")
matched.to_csv("matched.csv", index=False)
print(f"Wrote {len(matched)} rows to matched.csv")

#!/usr/bin/env python3
"""Compare two conda environment YAML files package by package.

Usage:
    python compare_envs.py env1.yml env2.yml

Reports packages unique to each env and packages present in both but
pinned to different versions. Reads any encoding (handles the UTF-16 /
null-byte files Windows tooling sometimes produces).
"""
import argparse
import sys

try:
    import yaml
except ImportError:
    sys.exit("PyYAML not found. Run: pip install pyyaml")


def load_yaml(path):
    """Load YAML by sniffing the encoding until one decodes without NUL bytes."""
    raw = open(path, "rb").read()
    for enc in ("utf-8-sig", "utf-16", "utf-8", "latin-1"):
        try:
            text = raw.decode(enc)
        except UnicodeDecodeError:
            continue
        if "\x00" in text:
            continue
        return yaml.safe_load(text)
    raise ValueError(f"Could not decode {path} as text")


def pkg_name(spec):
    for sep in ("==", "=", "<", ">", "~", "!"):
        if sep in spec:
            return spec.split(sep)[0].strip()
    return spec.strip()


def deps_map(env):
    """Flatten conda + pip deps into {package_name: full_spec}."""
    out = {}
    for dep in env.get("dependencies", []) or []:
        if isinstance(dep, dict) and "pip" in dep:
            for p in dep["pip"]:
                out[pkg_name(p)] = p + "  (pip)"
        elif isinstance(dep, str):
            out[pkg_name(dep)] = dep
    return out


def section(title, items):
    print(f"\n{title}  ({len(items)})")
    print("-" * len(title))
    for line in items:
        print(f"  {line}")
    if not items:
        print("  (none)")


def main():
    ap = argparse.ArgumentParser()
    ap.add_argument("env_a")
    ap.add_argument("env_b")
    args = ap.parse_args()

    a = deps_map(load_yaml(args.env_a))
    b = deps_map(load_yaml(args.env_b))

    only_a = sorted(f"{a[n]}" for n in a.keys() - b.keys())
    only_b = sorted(f"{b[n]}" for n in b.keys() - a.keys())
    shared = sorted(a.keys() & b.keys())

    diff_ver = [f"{n}: {a[n]}  vs  {b[n]}" for n in shared if a[n] != b[n]]
    same_ver = [n for n in shared if a[n] == b[n]]

    section(f"Only in {args.env_a}", only_a)
    section(f"Only in {args.env_b}", only_b)
    section("In both, DIFFERENT version", sorted(diff_ver))
    print(f"\nIn both, same version: {len(same_ver)} package(s)")


if __name__ == "__main__":
    main()







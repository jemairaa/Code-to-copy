# Section 1 — Load the two documents
import pandas as pd

# Edit these two paths to point at your files
doc1_path = "document1.csv"
doc2_path = "document2.csv"

# Read as text (dtype=str) so IDs and keys don't get changed into numbers.
# fillna("") turns blank cells into empty strings instead of NaN.
doc1 = pd.read_csv(doc1_path, dtype=str).fillna("")
doc2 = pd.read_csv(doc2_path, dtype=str).fillna("")

print("Doc 1 shape:", doc1.shape)
print("Doc 2 shape:", doc2.shape)

doc1.head()







# Section 2 — See the columns in each document
import string

# Pair each column with its Excel letter: A, B, C, ...
# (Assumes each file has at most 26 columns — tell me if a file has more.)
doc1_cols = dict(zip(string.ascii_uppercase, doc1.columns))
doc2_cols = dict(zip(string.ascii_uppercase, doc2.columns))

print("Doc 1 columns:")
for letter, name in doc1_cols.items():
    print(f"  {letter} = {name}")

print("\nDoc 2 columns:")
for letter, name in doc2_cols.items():
    print(f"  {letter} = {name}")




# Section 3 — Filter out US rows (but keep Alaska & Hawaii)

# Grab the real names of the country and state columns
country_col = doc1_cols["O"]
state_col   = doc1_cols["P"]

# Clean the values so comparisons are reliable:
# .str.strip() removes stray spaces, .str.upper() ignores capitalization.
country = doc1[country_col].str.strip().str.upper()
state   = doc1[state_col].str.strip().str.upper()

# A row counts as US if the country column says "US".
is_us = country == "US"

# ...but we keep Alaska and Hawaii even though they are US.
is_exception = state.isin(["ALASKA", "HAWAII"])

# Keep a row when it is NOT US, OR it is one of the exceptions.
keep = (~is_us) | is_exception

doc1_filtered = doc1[keep].copy()

print("Rows before:", len(doc1))
print("Rows after :", len(doc1_filtered))
print("Dropped    :", len(doc1) - len(doc1_filtered))

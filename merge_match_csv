# Section 1 — Load the two documents
import pandas as pd
from pathlib import Path

# Edit these two paths to point at your files
doc1_path = "document1.csv"
doc2_path = "document2.csv"

# Fail early with a clear message if a path is wrong
for path in (doc1_path, doc2_path):
    if not Path(path).exists():
        raise FileNotFoundError(f"Can't find: {path}  (check the path/filename)")

# Read as text (dtype=str) so IDs and keys don't get turned into numbers.
# fillna("") turns blank cells into empty strings instead of NaN.
doc1 = pd.read_csv(doc1_path, dtype=str).fillna("")
doc2 = pd.read_csv(doc2_path, dtype=str).fillna("")

# Trim stray spaces from the column HEADERS, so looking up a column
# by letter later never fails because of a hidden space in the title.
doc1.columns = doc1.columns.str.strip()
doc2.columns = doc2.columns.str.strip()

print("Doc 1 shape:", doc1.shape)
print("Doc 2 shape:", doc2.shape)

doc1.head()






# Section 2 — See the columns in each document

# Turn a 0-based position into an Excel-style column letter:
# 0->A, 1->B, ... 25->Z, 26->AA, 27->AB, ... 51->AZ, 52->BA, ...
def excel_letter(index):
    letters = ""
    index += 1  # Excel counts from 1, not 0
    while index > 0:
        index, remainder = divmod(index - 1, 26)
        letters = chr(ord("A") + remainder) + letters
    return letters

# Build a {letter: column_name} lookup for every column in a dataframe
def letter_map(df):
    return {excel_letter(i): name for i, name in enumerate(df.columns)}

doc1_cols = letter_map(doc1)
doc2_cols = letter_map(doc2)

print("Doc 1 columns:")
for letter, name in doc1_cols.items():
    print(f"  {letter} = {name}")

print("\nDoc 2 columns:")
for letter, name in doc2_cols.items():
    print(f"  {letter} = {name}")









# Section 3 — Filter out US rows (but keep Alaska & Hawaii)

# Helper: clean a text column so comparisons are reliable.
# Handles the sneaky stuff that makes an exact match silently fail.
def clean(series):
    return (
        series.astype(str)                      # ensure it's text
        .str.replace("\xa0", " ", regex=False)  # non-breaking space -> normal space
        .str.replace(r"\s+", " ", regex=True)   # collapse double/triple spaces -> one
        .str.strip()                            # trim leading/trailing spaces
        .str.upper()                            # ignore capitalization
    )

# Clean the country and state columns (computed fresh every run)
country = clean(doc1[doc1_cols["O"]])
state   = clean(doc1[doc1_cols["P"]])

# Each of these is a column of True/False, one value per row
is_us        = country.eq("UNITED STATES")
is_exception = state.isin(["ALASKA", "HAWAII"])

# Keep a row when it is NOT US, OR it is Alaska/Hawaii
keep = (~is_us) | is_exception
doc1_filtered = doc1[keep].copy()

# Report
print("Rows total       :", len(doc1))
print("Flagged as US     :", int(is_us.sum()))
print("AK/HI kept        :", int((is_us & is_exception).sum()))
print("Rows kept         :", len(doc1_filtered))
print("Rows dropped      :", len(doc1) - len(doc1_filtered))





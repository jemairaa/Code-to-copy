# Section 1 — Load the two documents
import pandas as pd
from pathlib import Path

# Edit these two paths to point at your files
doc1_path = "document1.csv"
doc2_path = "document2.csv"

# Fail early with a clear message if a path is wrong
for path in (doc1_path, doc2_path):
    if not Path(path).exists():
        raise FileNotFoundError(f"Can't find: {path}  (check the path/filename)")

# Read as text (dtype=str) so IDs and keys don't get turned into numbers.
# fillna("") turns blank cells into empty strings instead of NaN.
doc1 = pd.read_csv(doc1_path, dtype=str).fillna("")
doc2 = pd.read_csv(doc2_path, dtype=str).fillna("")

# Trim stray spaces from the column HEADERS, so looking up a column
# by letter later never fails because of a hidden space in the title.
doc1.columns = doc1.columns.str.strip()
doc2.columns = doc2.columns.str.strip()

print("Doc 1 shape:", doc1.shape)
print("Doc 2 shape:", doc2.shape)

doc1.head()


# Section 1b — Clean both files once, before anything else
import re

# Values that really mean "blank"
NA_PLACEHOLDERS = {"", "NAN", "NONE", "NULL", "N/A", "NA"}

def tidy(df):
    df = df.copy()

    # 1) Clean column NAMES (strip hidden/double spaces)
    df.columns = [
        re.sub(r"\s+", " ", str(c).replace("\xa0", " ")).strip()
        for c in df.columns
    ]

    # 2) Clean every VALUE in every column
    for col in df.columns:
        cleaned = (
            df[col].astype(str)
            .str.replace("\xa0", " ", regex=False)   # non-breaking space -> normal
            .str.replace(r"\s+", " ", regex=True)    # collapse repeated spaces
            .str.strip()                             # trim ends
        )
        # turn "nan", "none", "n/a", etc. into a real blank ""
        is_blank = cleaned.str.upper().isin(NA_PLACEHOLDERS)
        df[col] = cleaned.where(~is_blank, "")
    return df

doc1 = tidy(doc1)
doc2 = tidy(doc2)
print("Both files cleaned — names, whitespace, and blank placeholders.")



# Section 2 — See the columns in each document

# Turn a 0-based position into an Excel-style column letter:
# 0->A, 1->B, ... 25->Z, 26->AA, 27->AB, ... 51->AZ, 52->BA, ...
def excel_letter(index):
    letters = ""
    index += 1  # Excel counts from 1, not 0
    while index > 0:
        index, remainder = divmod(index - 1, 26)
        letters = chr(ord("A") + remainder) + letters
    return letters

# Build a {letter: column_name} lookup for every column in a dataframe
def letter_map(df):
    return {excel_letter(i): name for i, name in enumerate(df.columns)}

doc1_cols = letter_map(doc1)
doc2_cols = letter_map(doc2)

print("Doc 1 columns:")
for letter, name in doc1_cols.items():
    print(f"  {letter} = {name}")

print("\nDoc 2 columns:")
for letter, name in doc2_cols.items():
    print(f"  {letter} = {name}")









# Section 3 — Filter out US rows, but keep certain states

country_col = "country"   # <-- real names from Section 2
state_col   = "state"

# Helper: clean a text column so comparisons are reliable
# (handles hidden spaces and capitalization).
def clean(series):
    return (
        series.astype(str)
        .str.replace("\xa0", " ", regex=False)  # non-breaking space -> normal space
        .str.replace(r"\s+", " ", regex=True)   # collapse repeated spaces -> one
        .str.strip()                            # trim the ends
        .str.upper()                            # ignore capitalization
    )

country = clean(doc1[country_col])
state   = clean(doc1[state_col])

# States we keep even though they're in the US (type them in ANY case)
KEEP_PLACES = ["Alaska", "Hawaii", "Florida"]
keep_places = [p.strip().upper() for p in KEEP_PLACES]   # match clean()'s uppercasing

# True/False for every row
is_us        = country.eq("UNITED STATES")
is_exception = state.isin(keep_places)

# Keep a row when it is NOT US, OR it is one of the kept states
keep = (~is_us) | is_exception
doc1_filtered = doc1[keep].copy()

# Report
print("Rows total    :", len(doc1))
print("Flagged as US  :", int(is_us.sum()))
print("Kept anyway    :", int((is_us & is_exception).sum()))
print("Rows kept      :", len(doc1_filtered))
print("Rows dropped   :", len(doc1) - len(doc1_filtered))















# Section 4 — Build a dictionary of values for each important column

# List the columns you want a dictionary for (real names from Section 2).
# country_col and state_col are already defined in Section 3.
dict_columns = ["columnA", "columnB", "columnC", "columnM", country_col, state_col]

# For each column, collect its unique, non-blank values into a set
dictionaries = {}
for col in dict_columns:
    values = doc1_filtered[col].astype(str).str.strip()   # text, trimmed
    values = values[values != ""]                         # drop blank cells
    dictionaries[col] = set(values)                       # keep unique values

# Show how many unique values each column ended up with
for col, values in dictionaries.items():
    print(f"{col}: {len(values)} unique values")
















# Section 5 — Add Doc 2's columns (empty) at the FRONT of Doc 1

result = doc1_filtered.copy()

# Work out the names for the new Doc 2 columns, adding empty columns as we go
new_cols = []
for col in doc2.columns:
    new_name = col if col not in result.columns else col + "_doc2"  # avoid collisions
    new_cols.append(new_name)
    result[new_name] = ""     # empty for now; filled during the merge in Section 6

# Reorder: new Doc 2 columns first, then ALL the original Doc 1 columns unchanged
original_cols = list(doc1_filtered.columns)
result = result[new_cols + original_cols]

print("New columns added at front:")
print(" ", new_cols)
print("Original Doc 1 columns kept:", len(original_cols))
result.head()












# Section 6 — Fill the Doc 2 columns where the IATA keys match

doc1_key = "1"   # Doc 1's IATA column
doc2_key = "6"   # Doc 2's IATA column

# Clean a key: trim, uppercase, and turn blanks/nan into truly empty.
def clean_key(value):
    text = str(value).strip().upper()
    if text in ("", "NAN", "NONE", "NULL"):
        return ""
    return text

# Standardize the keys on both sides
result_key = result[doc1_key].map(clean_key)
doc2_keys  = doc2[doc2_key].map(clean_key)

# Build a lookup from Doc 2: key -> that row (drop blanks, keep first if repeated)
doc2_lookup = doc2.copy()
doc2_lookup["_key"] = doc2_keys
doc2_lookup = doc2_lookup[doc2_lookup["_key"] != ""]
doc2_lookup = doc2_lookup.drop_duplicates("_key", keep="first").set_index("_key")

# A row matches only if it HAS a key and that key exists in Doc 2
has_iata = result_key != ""
matched  = has_iata & result_key.isin(doc2_lookup.index)

# Copy each Doc 2 column's value into the matching rows
for original_col, new_name in zip(doc2.columns, new_cols):
    result.loc[matched, new_name] = result_key[matched].map(doc2_lookup[original_col])

# Report
print("Doc 1 rows total       :", len(result))
print("Doc 1 rows missing IATA :", int((~has_iata).sum()))
print("Rows matched            :", int(matched.sum()))
print("Rows with no match      :", int((~matched).sum()))

"""
SQLite -> PostgreSQL loader
---------------------------
Copies EVERY table from a SQLite .db file into a PostgreSQL database.
Same SQLAlchemy write approach as your old csv_to_postgres.py -- it just
reads from SQLite instead of a CSV, and loops over all the tables.

WHERE TO RUN IT:
    Run this from the env that has Python + the database libraries
    (that's j_python3.11, not athena_pg):

        conda activate j_python3.11
        python sqlite_to_postgres.py

    Your Postgres server (the athena_pg env) must be RUNNING at the same
    time -- this script connects to it over localhost:5432.
"""

import sqlite3
import sys

# ---- Make sure the needed packages are present, with a friendly message ----
try:
    import pandas as pd
    from sqlalchemy import create_engine, inspect
    from sqlalchemy.exc import SQLAlchemyError
except ModuleNotFoundError as e:
    print(f"Missing a required package: {e.name}")
    print("In your j_python3.11 env, run:")
    print("    pip install pandas sqlalchemy")
    raise SystemExit(1)

# Pick whichever Postgres driver you have (psycopg v3 preferred, psycopg2 fallback)
try:
    import psycopg  # noqa: F401  (psycopg v3)
    DRIVER = "psycopg"
except ModuleNotFoundError:
    try:
        import psycopg2  # noqa: F401
        DRIVER = "psycopg2"
    except ModuleNotFoundError:
        print("No Postgres driver found. In your j_python3.11 env, run:")
        print("    pip install \"psycopg[binary]\"")
        raise SystemExit(1)

# =============================================================================
# CONFIG -- edit these few values
# =============================================================================
# VERIFY THIS PATH. If your Documents folder is synced to OneDrive, the real
# path may look like  C:\Users\648685\OneDrive - Booz Allen Hamilton\Documents\my_sql.db
# Easiest way to get it exactly right: find my_sql.db in File Explorer,
# right-click it -> "Copy as path", and paste it between the quotes below.
SQLITE_PATH = r"C:\Users\648685\Documents\my_sql.db"

DB_USER     = "postgres"
DB_PASSWORD = "your_password"   # <-- the password you set during initdb
DB_HOST     = "localhost"
DB_PORT     = "5432"
DB_NAME     = "athena"          # the database you created with createdb
SCHEMA      = "public"          # where the tables land inside athena

IF_EXISTS   = "replace"         # "fail" | "replace" | "append"
CHUNK_SIZE  = 5_000             # rows written per batch (memory friendly)
# =============================================================================


def list_tables(conn):
    """Return all real table names in the SQLite file (skip internal ones)."""
    cur = conn.cursor()
    cur.execute(
        "SELECT name FROM sqlite_master "
        "WHERE type='table' AND name NOT LIKE 'sqlite_%' "
        "ORDER BY name;"
    )
    return [row[0] for row in cur.fetchall()]


def main():
    # 1. Open the SQLite file
    try:
        sqlite_conn = sqlite3.connect(SQLITE_PATH)
    except sqlite3.Error as e:
        print(f"Could not open SQLite file at:\n  {SQLITE_PATH}\n  {e}")
        sys.exit(1)

    tables = list_tables(sqlite_conn)
    if not tables:
        print("No tables found in the SQLite file. Nothing to copy.")
        sqlite_conn.close()
        sys.exit(0)
    print(f"Found {len(tables)} table(s): {', '.join(tables)}\n")

    # 2. Connect to Postgres
    url = f"postgresql+{DRIVER}://{DB_USER}:{DB_PASSWORD}@{DB_HOST}:{DB_PORT}/{DB_NAME}"
    try:
        engine = create_engine(url)
        with engine.connect():
            print(f"Connected to PostgreSQL database '{DB_NAME}' (driver: {DRIVER}).\n")
    except SQLAlchemyError as e:
        print("Could not connect to PostgreSQL. Common causes:")
        print("  - the server isn't running (start it in the athena_pg env)")
        print("  - wrong password")
        print(f"  - the '{DB_NAME}' database doesn't exist yet "
              f"(create it in pgAdmin: right-click Databases -> Create -> Database)")
        print(f"\nDetails: {e}")
        sqlite_conn.close()
        sys.exit(1)

    # 3. Copy each table over
    for table in tables:
        print(f"-> {table}: reading...", end=" ", flush=True)
        df = pd.read_sql(f'SELECT * FROM "{table}"', sqlite_conn)
        print(f"{len(df):,} rows x {len(df.columns)} cols, writing...", end=" ", flush=True)
        try:
            df.to_sql(
                name=table,
                con=engine,
                schema=SCHEMA,
                if_exists=IF_EXISTS,
                index=False,
                chunksize=CHUNK_SIZE,
            )
            print("done.")
        except SQLAlchemyError as e:
            print(f"FAILED: {e}")

    sqlite_conn.close()

    # 4. Show what's now in Postgres
    written = inspect(engine).get_table_names(schema=SCHEMA)
    print(f"\nTables now in {DB_NAME}.{SCHEMA}: {', '.join(written)}")
    print("Refresh the athena database in pgAdmin to see them.")


if __name__ == "__main__":
    main()
